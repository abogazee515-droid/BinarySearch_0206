#include <iostream>
using namespace std;

int arr[10];
int sizeArr;
int target;

void input() {
    while (true) {
        cout << "Enter number of elements (max 10): ";
        cin >> sizeArr;

        if (sizeArr <= 10) {
            break;
        } else {
            cout << "\n[!] Number of elements must not exceed 10. Try again.\n";
        }
    }

    cout << "\n=============================\n";
    cout << "      Enter Array Elements   \n";
    cout << "=============================\n";

    for (int i = 0; i < sizeArr; i++) {
        cout << "Element " << (i + 1) << " = ";
        cin >> arr[i];
    }
}

void bubbleSort() {
    int pass = 1;

    do {
        for (int j = 0; j <= sizeArr - 1 - pass; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
        pass++;
    } while (pass <= sizeArr - 1);
}

void display() {
    cout << "\n=====================================\n";
    cout << " Sorted Array (Ascending Order)\n";
    cout << "=====================================\n";

    for (int i = 0; i < sizeArr; i++) {
        cout << arr[i];
        if (i < sizeArr - 1) {
            cout << " -> ";
        }
    }
    cout << endl;
}

void binarySearch() {
    char repeat;

    do {
        cout << "\n=============================\n";
        cout << "      Binary Search\n";
        cout << "=============================\n";

        cout << "Enter element to search: ";
        cin >> target;
        int low = 0;
        int high = sizeArr - 1;

        do {
            int mid = (low + high) / 2;

            if (arr[mid] == target) {
                cout << "\n[✓] Element " << target << " found at index " << mid << endl;
                return;
            }

            if (target < arr[mid]) {
                high = mid - 1;
            }

            if (target > arr[mid]) {
                low = mid + 1;
            }

        } while (low <= high);

        if (low > high) {
            cout << "\n[x] Element " << target << " not found in array.\n";
        }

        cout << "Search again? (y/n): ";
        cin >> repeat;

    } while (repeat == 'y' || repeat == 'Y');
}

int main() {
    input();
    bubbleSort();
    display();
    binarySearch();
}
