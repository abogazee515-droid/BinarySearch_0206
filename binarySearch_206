#include <iostream>
using namespace std;

int arr[10];
int sizeArr;
int target;

void input() {
    while (true) {
        cout << "Enter number of elements (max 10): ";
        cin >> sizeArr;

        if (sizeArr <= 10) {
            break;
        } else {
            cout << "\n[!] Number of elements must not exceed 10. Try again.\n";
        }
    }

    cout << "\n=============================\n";
    cout << "      Enter Array Elements   \n";
    cout << "=============================\n";

    for (int i = 0; i < sizeArr; i++) {
        cout << "Element " << (i + 1) << " = ";
        cin >> arr[i];
    }
}
